  var ca = $("content-area");
  try {
  if(currentUser.role==="owner"){
    if(page==="dash") ca.innerHTML = renderAdminDash();
    else if(page==="all-tuts") ca.innerHTML = renderAdminTuts();
    else if(page==="users-mgmt") ca.innerHTML = renderAdminUsers();
    else if(page==="analytics") ca.innerHTML = renderAdminAnalytics();
    else if(page==="money") ca.innerHTML = renderAdminMoney();
    else if(page==="security") ca.innerHTML = renderAdminSecurity();
    else if(page==="settings") ca.innerHTML = renderAdminSettings();
