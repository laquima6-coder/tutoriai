var quizState = {};
function openQuizModal(id) {
  var t=getTut(id);
  if(!t)return;
  quizState = {tutId:id,answers:{},submitted:false,questions:null};
  var body='<div class="ai-loader"><div class="ai-orb">🧠</div><div style="font-weight:700">Generando preguntas con IA...</div><div style="color:var(--mut);font-size:12px">Claude crea preguntas específicas para este tutorial</div></div>';
  openModal("🧠 Quiz — "+t.title, body, null, true);
  generateQuiz(t);
}

async function generateQuiz(t) {
  var prompt='Genera 4 preguntas de opción múltiple en '+t.lang+' sobre: "'+t.title+'". Responde SOLO con JSON válido sin markdown: [{"question":"texto","options":["A) ...","B) ...","C) ...","D) ..."],"correct":0}]. "correct" es el índice 0-3 de la respuesta correcta.';
  var r=await callAI(prompt);
  var questions;
  try {
    questions=JSON.parse(r.replace(/```json|```/g,"").trim()).slice(0,4);
  } catch(e) {
    questions=[
      {question:"¿Cuál es el primer paso para "+t.title.toLowerCase()+"?",options:["A) Verificar acceso","B) Saltar pasos","C) Ignorar instrucciones","D) Improvisar"],correct:0},
      {question:"¿Qué hacer antes de finalizar el proceso?",options:["A) Cerrar sin guardar","B) Verificar y guardar","C) Nada especial","D) Llamar a soporte"],correct:1},
      {question:"¿Cuándo se considera completado?",options:["A) Al abrirlo","B) A la mitad","C) Al completar todos los pasos","D) Nunca"],correct:2},
      {question:"¿Por qué seguir el proceso correctamente?",options:["A) No es importante","B) Mejora eficiencia y reduce errores","C) Solo por cumplir reglas","D) Es opcional"],correct:1}
    ];
  }
  quizState.questions=questions;
  renderQuizQuestions();
}

function renderQuizQuestions() {
  var qs=quizState.questions;
  var html='<div style="margin-bottom:14px;font-size:12px;color:var(--mut)">Respondé las '+qs.length+' preguntas</div>'
    +qs.map(function(q,qi){
      return '<div class="quiz-q"><div style="font-weight:600;font-size:13px;margin-bottom:7px">'+(qi+1)+'. '+q.question+'</div>'
        +q.options.map(function(opt,oi){
          var sel=quizState.answers[qi]===oi;
          return '<div class="quiz-opt'+(sel?" sel":"")+'" onclick="selectAnswer('+qi+','+oi+')"><div class="radio-dot"></div>'+opt+'</div>';
        }).join("")+'</div>';
    }).join("");
  $("modal-body").innerHTML=html;
  var answered=Object.keys(quizState.answers).length;
  $("modal-foot").innerHTML='<button class="btn btn-s btn-sm" onclick="closeModal()">Cancelar</button><button class="btn btn-p btn-sm" onclick="submitQuiz()" '+(answered<qs.length?"disabled":"")+'>Enviar ('+answered+'/'+qs.length+')</button>';
  show("modal-foot");
}

function selectAnswer(qi,oi) {
  if(quizState.submitted)return;
  quizState.answers[qi]=oi;
  renderQuizQuestions();
}

function submitQuiz() {
  var qs=quizState.questions;
  var correct=0;
  qs.forEach(function(q,i){if(quizState.answers[i]===q.correct)correct++;});
  var score=Math.round((correct/qs.length)*100);
  var t=getTut(quizState.tutId);
  var emoji=score>=80?"🎉":score>=60?"👍":"💪";
  var msg=score>=80?"¡Excelente! Podés obtener tu certificado.":score>=60?"Buen trabajo.":"Repasá el tutorial e intentá de nuevo.";
  var resultsGrid='<div class="sg2 stat-grid">'+qs.map(function(q,i){var ok=quizState.answers[i]===q.correct;return '<div style="padding:9px 11px;border-radius:8px;background:'+(ok?"rgba(16,185,129,.08)":"rgba(239,68,68,.08)")+';border:1px solid '+(ok?"rgba(16,185,129,.22)":"rgba(239,68,68,.22)")+';"><div style="font-size:10.5px;font-weight:700;color:'+(ok?"var(--grn)":"var(--red)")+'">'+(ok?"✓ Correcta":"✗ Incorrecta")+'</div><div style="font-size:10.5px;margin-top:1px;color:var(--lt)">'+q.question.slice(0,55)+'…</div></div>';}).join("")+'</div>';
  $("modal-body").innerHTML='<div style="text-align:center;padding:18px 0"><div style="font-size:54px;margin-bottom:12px">'+emoji+'</div><div style="font-size:22px;font-weight:800;margin-bottom:7px">Score: <span style="color:'+(score>=80?"var(--grn)":score>=60?"var(--org)":"var(--red)")+'">'+score+'%</span></div><div style="color:var(--mut);font-size:13px;margin-bottom:18px">'+msg+'</div>'+resultsGrid+'</div>';
  
  // Save completion
  if(score>=60&&t){
    var existing=completions.find(function(c){return c.userId===currentUser.id&&c.tutId===t.id;});
    if(!existing){
      completions.push({userId:currentUser.id,tutId:t.id,score:score,date:new Date().toISOString().slice(0,10),certified:t.certOn});
    }
  }
  
  var footHtml='<button class="btn btn-s btn-sm" onclick="closeModal()">Cerrar</button>';
  if(score>=60&&t&&t.certOn) footHtml+='<button class="btn btn-p btn-sm" onclick="closeModal();openCertModal('+t.id+')">🎓 Obtener Certificado</button>';
  if(score<60) footHtml+='<button class="btn btn-s btn-sm" onclick="quizState.answers={};renderQuizQuestions()">Intentar de nuevo</button>';
  $("modal-foot").innerHTML=footHtml;
  show("modal-foot");
  toast("Quiz completado! Score: "+score+"%");
  buildSidebar();
}

