<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="theme-color" content="#07090F"/>
<title>TutorAI — Capacitación con IA</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07090F;--surf:#0C1018;--card:#111520;--bdr:#1C2438;
  --acc:#5B7CFA;--v2:#8B5CF6;--grn:#10B981;--org:#F59E0B;--red:#EF4444;
  --txt:#DDE4F5;--mut:#4A5A7A;--lt:#8A9AC0;
  --grad:linear-gradient(135deg,#5B7CFA,#8B5CF6);
}
html,body{min-height:100%;background:var(--bg);color:var(--txt);font-family:'Segoe UI',system-ui,sans-serif}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:3px}
button{cursor:pointer;font-family:inherit;border:none;outline:none}
input,select,textarea{font-family:inherit;outline:none}
a{text-decoration:none}

/* LAYOUT */
.hidden{display:none!important}
.page{min-height:100vh}

/* AUTH */
#auth-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;background:var(--bg);position:relative;overflow:hidden}
.auth-orb{position:absolute;border-radius:50%;filter:blur(120px);pointer-events:none}
.auth-box{background:rgba(12,16,24,.97);border:1px solid var(--bdr);border-radius:22px;width:100%;max-width:420px;padding:32px;position:relative;z-index:1}
.auth-logo{display:flex;align-items:center;gap:10px;margin-bottom:24px;justify-content:center}
.auth-mark{width:44px;height:44px;background:var(--grad);border-radius:13px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:20px;color:#fff}
.auth-brand{font-size:22px;font-weight:800;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.auth-h{font-size:24px;font-weight:800;margin-bottom:4px}
.auth-s{color:var(--mut);font-size:13px;margin-bottom:20px}
.auth-tabs{display:flex;background:var(--card);border:1px solid var(--bdr);border-radius:9px;padding:3px;margin-bottom:18px}
.auth-tab{flex:1;padding:8px;border-radius:7px;font-size:13px;font-weight:600;background:none;color:var(--mut);transition:.15s}
.auth-tab.on{background:var(--grad);color:#fff}
.hints{background:rgba(91,124,250,.07);border:1px solid rgba(91,124,250,.15);border-radius:9px;padding:12px;margin-bottom:16px;font-size:12px;color:var(--lt);line-height:1.8}
.hints strong{color:var(--acc)}
.fg{margin-bottom:13px}
.fg label{display:block;font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px}
.fg input,.fg select{width:100%;background:var(--card);border:1px solid var(--bdr);border-radius:8px;padding:9px 12px;color:var(--txt);font-size:13px;transition:.15s}
.fg input:focus,.fg select:focus{border-color:var(--acc)}
.err-msg{color:var(--red);font-size:12px;font-weight:600;margin-bottom:10px}
.dvd{display:flex;align-items:center;gap:9px;margin:13px 0;color:var(--mut);font-size:12px}
.dvd::before,.dvd::after{content:'';flex:1;height:1px;background:var(--bdr)}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;transition:.15s;border:none}
.btn-p{background:var(--grad);color:#fff}
.btn-p:hover{opacity:.88}
.btn-s{background:var(--card);color:var(--txt);border:1px solid var(--bdr)}
.btn-s:hover{border-color:var(--acc);color:var(--acc)}
.btn-d{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.2)}
.btn-full{width:100%;padding:11px}
.btn-sm{padding:5px 12px;font-size:12px}

/* LAYOUT */
.shell{display:flex;min-height:100vh}
.sidebar{width:220px;background:var(--surf);border-right:1px solid var(--bdr);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;overflow-y:auto}
.main-area{margin-left:220px;display:flex;flex-direction:column;min-height:100vh}
.topbar{height:54px;background:rgba(12,16,24,.95);border-bottom:1px solid var(--bdr);display:flex;align-items:center;padding:0 18px;gap:10px;position:sticky;top:0;z-index:50}
.content-area{padding:20px;flex:1}

/* SIDEBAR */
.logo-row{padding:14px 16px;display:flex;align-items:center;gap:9px;border-bottom:1px solid var(--bdr)}
.logo-dot{width:30px;height:30px;background:var(--grad);border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:13px;color:#fff;flex-shrink:0}
.logo-name{font-size:15px;font-weight:800;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.plan-pill{font-size:9px;font-weight:700;padding:2px 6px;border-radius:20px;margin-left:auto;text-transform:uppercase}
.nav-area{padding:8px 6px;flex:1}
.nav-sec{font-size:9px;font-weight:700;letter-spacing:1.5px;color:var(--mut);padding:9px 8px 4px;text-transform:uppercase}
.nav-btn{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:8px;font-size:13px;font-weight:500;color:var(--mut);transition:.14s;margin-bottom:1px;background:none;width:100%;text-align:left;border:none}
.nav-btn:hover{background:rgba(91,124,250,.08);color:var(--txt)}
.nav-btn.on{background:rgba(91,124,250,.14);color:var(--acc);font-weight:600}
.nav-badge{margin-left:auto;background:var(--acc);color:#fff;border-radius:20px;padding:1px 6px;font-size:9px;font-weight:700}
.nav-badge-red{background:var(--red)}
.sb-foot{padding:10px;border-top:1px solid var(--bdr)}
.user-card{display:flex;align-items:center;gap:8px;padding:8px;border-radius:8px;background:var(--card)}
.ava{width:30px;height:30px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;color:#fff}

/* TOPBAR */
.search-bar{flex:1;max-width:340px;display:flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--bdr);border-radius:8px;padding:6px 11px}
.search-bar input{background:none;border:none;color:var(--txt);font-size:13px;flex:1;outline:none}
.icon-btn{width:32px;height:32px;border-radius:7px;background:var(--card);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;color:var(--mut);transition:.14s;font-size:15px}
.icon-btn:hover{color:var(--txt);border-color:var(--acc)}

/* STATS */
.stat-grid{display:grid;gap:12px;margin-bottom:18px}
.sg4{grid-template-columns:repeat(4,1fr)}
.sg3{grid-template-columns:repeat(3,1fr)}
.sg2{grid-template-columns:repeat(2,1fr)}
.stat-card{background:var(--card);border:1px solid var(--bdr);border-radius:12px;padding:15px;border-top:2px solid var(--acc)}
.stat-label{font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.6px;margin-bottom:5px}
.stat-val{font-size:26px;font-weight:800}
.stat-trend{font-size:11px;font-weight:600;margin-top:3px;color:var(--grn)}

/* CARDS */
.card{background:var(--card);border:1px solid var(--bdr);border-radius:12px}
.card-head{padding:13px 16px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between}
.card-title{font-weight:700;font-size:13px}
.card-body{padding:15px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:15px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}

/* TABLE */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
th{font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--mut);padding:8px 12px;text-align:left;border-bottom:1px solid var(--bdr)}
td{padding:9px 12px;border-bottom:1px solid rgba(28,36,56,.5);font-size:12px;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(91,124,250,.03)}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:9.5px;font-weight:700}
.b-grn{background:rgba(16,185,129,.12);color:var(--grn)}
.b-org{background:rgba(245,158,11,.12);color:var(--org)}
.b-blue{background:rgba(91,124,250,.12);color:var(--acc)}
.b-purple{background:rgba(139,92,246,.12);color:var(--v2)}
.b-red{background:rgba(239,68,68,.12);color:var(--red)}
.b-gray{background:rgba(74,90,122,.12);color:var(--mut)}
.tag{display:inline-flex;padding:1px 6px;border-radius:4px;font-size:9.5px;font-weight:600;background:rgba(91,124,250,.1);color:var(--acc);margin:1px}

/* TUT CARDS */
.tut-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:13px}
.tut-card{background:var(--card);border:1px solid var(--bdr);border-radius:12px;overflow:hidden;transition:.18s;cursor:pointer}
.tut-card:hover{border-color:rgba(91,124,250,.4);transform:translateY(-2px)}
.tut-thumb{height:88px;display:flex;align-items:center;justify-content:center;font-size:36px;position:relative}
.tut-body{padding:12px}
.tut-title{font-weight:700;font-size:13px;margin-bottom:5px;line-height:1.4}
.tut-meta{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px}
.tut-stats{display:flex;justify-content:space-between;font-size:10px;color:var(--mut);margin-bottom:8px}
.tut-actions{display:flex;gap:4px;flex-wrap:wrap}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;display:flex;align-items:center;justify-content:center;padding:14px;backdrop-filter:blur(5px)}
.modal{background:var(--surf);border:1px solid var(--bdr);border-radius:18px;width:100%;max-width:600px;max-height:92vh;overflow-y:auto;animation:pop .2s ease}
.modal-lg{max-width:740px}
@keyframes pop{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.modal-head{padding:16px 19px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-size:16px;font-weight:800}
.modal-body{padding:18px}
.modal-foot{padding:13px 19px;border-top:1px solid var(--bdr);display:flex;gap:8px;justify-content:flex-end}

/* FORM */
.form-group{margin-bottom:13px}
.form-group label{display:block;font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px}
.form-group input,.form-group select,.form-group textarea{width:100%;background:var(--card);border:1px solid var(--bdr);border-radius:8px;padding:8px 12px;color:var(--txt);font-size:13px;transition:.15s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--acc)}
.form-group textarea{resize:vertical;min-height:70px}
select option{background:var(--card)}

/* SOURCE GRID */
.src-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:13px}
.src-item{background:var(--card);border:1.5px solid var(--bdr);border-radius:9px;padding:10px 7px;text-align:center;cursor:pointer;transition:.14s}
.src-item:hover,.src-item.on{border-color:var(--acc);background:rgba(91,124,250,.06)}
.src-item.on{box-shadow:0 0 0 2px rgba(91,124,250,.15)}
.out-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.out-item{background:var(--card);border:1.5px solid var(--bdr);border-radius:9px;padding:10px;cursor:pointer;transition:.14s;display:flex;flex-direction:column;gap:3px}
.out-item:hover,.out-item.on{border-color:var(--v2);background:rgba(139,92,246,.06)}
.out-item.on{box-shadow:0 0 0 2px rgba(139,92,246,.12)}
.drop-zone{border:2px dashed var(--bdr);border-radius:9px;padding:24px;text-align:center;color:var(--mut)}

/* AI LOADER */
.ai-loader{display:flex;flex-direction:column;align-items:center;gap:12px;padding:30px;text-align:center}
.ai-orb{width:60px;height:60px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:26px;animation:pulse 1.4s ease-in-out infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
.ai-step{display:flex;align-items:center;gap:8px;padding:5px 0;font-size:12px;color:var(--mut)}
.ai-step.done{color:var(--grn)}.ai-step.cur{color:var(--txt);font-weight:600}
.prog-bar{height:4px;background:var(--bdr);border-radius:3px;overflow:hidden;margin:5px 0}
.prog-fill{height:100%;border-radius:3px;background:var(--grad);transition:width .3s}

/* STEP BOXES */
.step-box{background:var(--bg);border-left:3px solid var(--acc);border-radius:0 8px 8px 0;padding:10px 13px;margin-bottom:8px}
.step-num{font-size:9px;font-weight:700;color:var(--acc);text-transform:uppercase;margin-bottom:2px}

/* QUIZ */
.quiz-q{background:var(--bg);border:1px solid var(--bdr);border-radius:9px;padding:13px;margin-bottom:9px}
.quiz-opt{display:flex;align-items:center;gap:9px;padding:8px 11px;border-radius:7px;border:1.5px solid var(--bdr);margin-top:7px;cursor:pointer;transition:.14s;font-size:13px}
.quiz-opt:hover{border-color:var(--acc);background:rgba(91,124,250,.05)}
.quiz-opt.sel{border-color:var(--acc);background:rgba(91,124,250,.1);color:var(--acc);font-weight:600}
.quiz-opt.correct{border-color:var(--grn);background:rgba(16,185,129,.1);color:var(--grn)}
.quiz-opt.wrong{border-color:var(--red);background:rgba(239,68,68,.1);color:var(--red)}
.radio-dot{width:15px;height:15px;border-radius:50%;border:2px solid var(--bdr);flex-shrink:0;transition:.14s}
.quiz-opt.sel .radio-dot{border-color:var(--acc);background:var(--acc)}

/* CERT */
.cert-wrap{background:var(--bg);border:1.5px solid var(--acc);border-radius:14px;padding:30px;text-align:center;position:relative;overflow:hidden}
.cert-seal{width:62px;height:62px;background:var(--grad);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto 12px}
.cert-lbl{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--mut);margin-bottom:8px}
.cert-name{font-size:24px;font-weight:800;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:7px 0}

/* CHAT */
.chat-container{display:flex;flex-direction:column;height:360px}
.chat-msgs{flex:1;overflow-y:auto;padding:13px;display:flex;flex-direction:column;gap:9px}
.chat-msg{max-width:80%;padding:9px 13px;border-radius:11px;font-size:13px;line-height:1.6}
.chat-msg.user{background:var(--grad);color:#fff;align-self:flex-end;border-radius:11px 11px 3px 11px}
.chat-msg.bot{background:rgba(28,36,56,.9);color:var(--txt);align-self:flex-start;border-radius:11px 11px 11px 3px}
.chat-input-row{display:flex;gap:7px;padding:11px 13px;border-top:1px solid var(--bdr)}
.chat-input-row input{flex:1;background:var(--card);border:1px solid var(--bdr);border-radius:8px;padding:8px 12px;color:var(--txt);font-size:13px}
.chat-input-row input:focus{border-color:var(--acc)}

/* PLAN CARDS */
.plan-card{background:var(--card);border:1.5px solid var(--bdr);border-radius:12px;padding:18px}
.plan-card.featured{border-color:var(--acc);background:rgba(91,124,250,.05)}
.plan-price{font-size:24px;font-weight:800;margin:7px 0}
.plan-feat{font-size:12px;color:var(--lt);margin:3px 0;display:flex;align-items:center;gap:5px}

/* TOGGLE */
.toggle-row{display:flex;align-items:center;gap:9px;font-size:13px;color:var(--lt);padding:5px 0;cursor:pointer}
.tog{width:33px;height:18px;border-radius:10px;position:relative;transition:.16s;flex-shrink:0}
.tog.on{background:var(--grn)}.tog.off{background:var(--bdr)}
.tog::after{content:'';position:absolute;width:12px;height:12px;background:#fff;border-radius:50%;top:3px;transition:.16s}
.tog.on::after{left:17px}.tog.off::after{left:3px}

/* CHART */
.chart-bars{display:flex;align-items:flex-end;gap:5px;height:76px}
.chart-bar{flex:1;border-radius:4px 4px 0 0;background:var(--grad);opacity:.55;transition:.2s;min-height:3px}
.chart-bar:hover{opacity:1}

/* TOAST */
.toast-wrap{position:fixed;bottom:18px;right:18px;z-index:999;display:flex;flex-direction:column;gap:7px}
.toast{padding:10px 16px;border-radius:10px;font-weight:600;font-size:13px;display:flex;align-items:center;gap:7px;border:1px solid;animation:pop .22s ease}
.toast-ok{background:rgba(16,185,129,.13);border-color:rgba(16,185,129,.28);color:var(--grn)}
.toast-info{background:rgba(91,124,250,.13);border-color:rgba(91,124,250,.28);color:var(--acc)}

/* PAGE HEAD */
.page-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;gap:12px;flex-wrap:wrap}
.page-title{font-size:22px;font-weight:800;line-height:1.1}
.page-sub{color:var(--mut);font-size:12px;margin-top:3px}
.empty{text-align:center;padding:42px;color:var(--mut)}
.tabs{display:flex;gap:2px;background:var(--card);border:1px solid var(--bdr);border-radius:8px;padding:3px}
.tab-btn{padding:5px 12px;border-radius:6px;font-size:12px;font-weight:600;color:var(--mut);background:none;border:none;transition:.14s;white-space:nowrap}
.tab-btn.on{background:var(--grad);color:#fff}
.pbar-wrap{height:4px;background:var(--bdr);border-radius:3px;overflow:hidden;margin:5px 0}
.pbar-fill{height:100%;border-radius:3px;background:var(--grad);transition:width .3s}
.sep{height:1px;background:var(--bdr);margin:14px 0}
.pending-box{background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.18);border-radius:12px;padding:14px;margin-bottom:16px}
.pending-item{display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--card);border:1px solid var(--bdr);border-radius:8px;margin-bottom:7px}
.upsell-box{margin-top:15px;background:linear-gradient(135deg,rgba(91,124,250,.09),rgba(139,92,246,.09));border:1px solid rgba(91,124,250,.2);border-radius:12px;padding:15px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.assigned-item{display:flex;align-items:center;gap:12px;padding:13px 15px;background:var(--card);border:1px solid var(--bdr);border-radius:12px;margin-bottom:8px}
.template-card{background:var(--card);border:1px solid var(--bdr);border-radius:12px;padding:16px;cursor:pointer;transition:.18s}
.template-card:hover{border-color:rgba(91,124,250,.4);transform:translateY(-2px)}
.act-item{display:flex;gap:9px;padding:7px 0;border-bottom:1px solid rgba(28,36,56,.5)}
.act-dot{width:7px;height:7px;border-radius:50%;background:var(--acc);margin-top:5px;flex-shrink:0}
.sec-item{display:flex;align-items:center;gap:10px;padding:11px;background:var(--card);border:1px solid var(--bdr);border-radius:9px;margin-bottom:7px}

/* RESPONSIVE */
@media(max-width:700px){
  .sidebar{display:none;position:fixed;z-index:200;width:100%;max-width:280px}
  .sidebar.open{display:flex!important}
  .main-area{margin-left:0!important}
  #menu-btn{display:flex!important}
  .sg4{grid-template-columns:repeat(2,1fr)}
  .sg4{grid-template-columns:repeat(2,1fr)}
  .g2{grid-template-columns:1fr}
  .g3{grid-template-columns:repeat(2,1fr)}
  .src-grid{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>

<!-- AUTH PAGE -->
<div id="auth-page">
  <div class="auth-orb" style="width:500px;height:500px;background:#5B7CFA;top:-150px;right:-80px;opacity:.07"></div>
  <div class="auth-orb" style="width:380px;height:380px;background:#8B5CF6;bottom:-100px;left:-80px;opacity:.07"></div>
  <div class="auth-box">
    <div class="auth-logo">
      <div class="auth-mark">T</div>
      <span class="auth-brand">TutorAI</span>
    </div>
    <div class="auth-h" id="auth-title">Bienvenido 👋</div>
    <div class="auth-s" id="auth-sub">Entrá a tu plataforma de capacitación</div>
    <div class="auth-tabs">
      <button class="auth-tab on" onclick="switchTab('login')">Iniciar Sesión</button>
      <button class="auth-tab" onclick="switchTab('register')">Registrarse</button>
    </div>
    <div class="hints hidden" id="demo-hints"></div>
    <div id="name-field" class="fg hidden">
      <label>Nombre completo</label>
      <input type="text" id="inp-name" placeholder="Tu nombre...">
    </div>
    <div class="fg">
      <label>Email</label>
      <input type="email" id="inp-email" placeholder="tu@empresa.com">
    </div>
    <div class="fg">
      <label>Contraseña</label>
      <input type="password" id="inp-pass" placeholder="••••••••">
    </div>
    <div class="err-msg hidden" id="auth-err"></div>
    <button class="btn btn-p btn-full" id="auth-btn" onclick="doAuth()">Entrar a TutorAI →</button>
