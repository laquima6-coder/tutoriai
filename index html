async function sendChat() {
  var inp=$("chat-inp");
  if(!inp)return;
  var q=inp.value.trim();
  if(!q)return;
  inp.value="";
  var t=getTut(chatTutId);
  chatMsgs.push({role:"user",text:q});
  chatMsgs.push({role:"bot",text:"●●●",loading:true});
  updateChatUI();
  var sys=t?"Eres un asistente de capacitacion conciso para el tutorial de "+t.dept+". Responde en "+t.lang+", maximo 3 parrafos cortos.":"Eres un asistente de capacitacion.";
  var r=await callAI("Pregunta: "+q,sys);
  chatMsgs[chatMsgs.length-1]={role:"bot",text:r||"No pude conectar. Intentá de nuevo."};
  updateChatUI();
}

function updateChatUI() {
  var area=$("chat-msgs-area");
  if(!area)return;
  area.innerHTML=chatMsgs.map(function(m){return '<div class="chat-msg '+m.role+'">'+(m.loading?"●●●":m.text)+'</div>';}).join("");
  area.scrollTop=area.scrollHeight;
}

