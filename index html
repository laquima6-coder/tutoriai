function switchTab(mode) {
  authMode = mode;
  var tabs = document.querySelectorAll(".auth-tab");
  tabs[0].classList.toggle("on", mode==="login");
  tabs[1].classList.toggle("on", mode==="register");
  if(mode==="login"){
    $("auth-title").textContent = "Bienvenido 👋";
    $("auth-sub").textContent = "Entrá a tu plataforma de capacitación";
    $("auth-btn").textContent = "Entrar a TutorAI →";
    hide("demo-hints");
    hide("name-field");
  } else {
    $("auth-title").textContent = "Crear cuenta gratis";
    $("auth-sub").textContent = "Generá tutoriales con IA desde hoy";
    $("auth-btn").textContent = "Crear cuenta gratis →";
    hide("demo-hints");
    show("name-field");
  }
  hide("auth-err");
}

function doAuth() {
  var email = $("inp-email").value.trim();
  var pass = $("inp-pass").value.trim();
  var err = $("auth-err");
  hide("auth-err");

  // Owner - acceso local sin base de datos
  if(email===OWNER.email && pass===OWNER.password){ loginAs(OWNER); return; }

  var btn = $("auth-btn");
  var originalText = btn.textContent;
  btn.textContent = "Cargando...";
  btn.disabled = true;

  if(authMode === "login") {
    fetch("/api/chat",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({action:"login",data:{email:email,password:pass}})})
      .then(function(r){return r.json();})
      .then(function(d){
        btn.textContent=originalText; btn.disabled=false;
        if(d.error){err.textContent="⚠ "+d.error;show("auth-err");return;}
        var u=d.user; u.role="user";
        loginAs(u);
      })
      .catch(function(){btn.textContent=originalText;btn.disabled=false;err.textContent="⚠ Error de conexión";show("auth-err");});
  } else {
    var name = $("inp-name").value.trim();
    if(!name||!email||!pass){btn.textContent=originalText;btn.disabled=false;err.textContent="⚠ Completá todos los campos";show("auth-err");return;}
    fetch("/api/chat",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({action:"register",data:{name:name,email:email,password:pass}})})
      .then(function(r){return r.json();})
      .then(function(d){
        btn.textContent=originalText; btn.disabled=false;
        if(d.error){err.textContent="⚠ "+d.error;show("auth-err");return;}
        var u=d.user; u.role="user";
        loginAs(u);
      })
      .catch(function(){btn.textContent=originalText;btn.disabled=false;err.textContent="⚠ Error de conexión";show("auth-err");});
  }
}

function loginAs(u) {
  currentUser = u;
  hide("auth-page");
  show("app-shell");
  try {
    buildSidebar();
  } catch(e) {
    alert("Error buildSidebar: " + e.message);
    return;
  }
  try {
    goPage(currentUser.role === "owner" ? "dash" : "home");
  } catch(e) {
    alert("Error goPage: " + e.message);
    var ca = $("content-area");
    if(ca) ca.innerHTML = '<div style="padding:20px;color:red">Error: ' + e.message + '</div>';
  }
}

function logout() {
  currentUser = null;
  hide("app-shell");
  show("auth-page");
  $("inp-email").value="";
  $("inp-pass").value="";
}

