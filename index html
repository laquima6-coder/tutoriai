      +'<div class="g2"><div class="form-group"><label>Departamento</label><select onchange="newTutState.dept=this.value">'+depts.map(function(d){return '<option'+(s.dept===d?" selected":"")+'>'+d+'</option>';}).join("")+'</select></div>'
      +'<div class="form-group"><label>Idioma</label><select onchange="newTutState.lang=this.value">'+LANGS.slice(0,maxL).map(function(l){return '<option'+(s.lang===l?" selected":"")+'>'+l+'</option>';}).join("")+'</select></div></div>'
    var availOuts=currentUser.role==="owner"?outs:outs.filter(function(o){return plan.types.indexOf(o.id)>-1;});
      +'<div style="background:var(--bg);border:1px solid var(--bdr);border-radius:9px;padding:13px;margin-bottom:13px"><div style="font-weight:700;font-size:12.5px;margin-bottom:10px">⚙️ Opciones</div>'
      +'<div class="toggle-row" onclick="newTutState.quizOn=!newTutState.quizOn;renderNewTutStep()"><div class="tog '+(s.quizOn?"on":"off")+'"></div><span>Activar quiz al finalizar</span><span class="badge b-purple" style="margin-left:auto">🧠 +valor</span></div>'
      +'<div class="toggle-row" style="margin-top:8px" onclick="newTutState.certOn=!newTutState.certOn;renderNewTutStep()"><div class="tog '+(s.certOn?"on":"off")+'"></div><span>Emitir certificado al aprobar</span><span class="badge" style="margin-left:auto;background:rgba(6,182,212,.12);color:#06B6D4">🎓 +valor</span></div>'
      +'</div>';
    var otherUsers=users.filter(function(u){return u.id!==currentUser.id;});
    if(otherUsers.length>0){
      body+='<div class="form-group"><label>Asignar a miembros</label>'+otherUsers.map(function(u){return '<label style="display:flex;align-items:center;gap:9px;padding:8px 10px;background:var(--bg);border:1px solid var(--bdr);border-radius:7px;cursor:pointer;margin-bottom:6px"><input type="checkbox" style="width:auto"'+(s.assignTo.indexOf(u.id)>-1?" checked":"")+' onchange="if(this.checked){newTutState.assignTo.push('+u.id+')}else{newTutState.assignTo=newTutState.assignTo.filter(function(x){return x!=='+u.id+'});}"><div class="ava" style="width:24px;height:24px;font-size:9px">'+u.avatar+'</div><span style="font-size:12px">'+u.name+'</span><span class="badge b-gray" style="margin-left:auto">'+u.plan+'</span></label>';}).join("")+'</div>';
    }
    foot='<button class="btn btn-s btn-sm" onclick="newTutState.step=1;renderNewTutStep()">← Atrás</button><button class="btn btn-p btn-sm" onclick="runAIGeneration()">🤖 Generar con IA</button>';
  }

  else if(s.step===3){
    var aiSteps=["Analizando fuente...","Extrayendo contenido...","Estructurando pasos...","Traduciendo al "+s.lang+"...","Aplicando formato "+s.out+"...","Optimizando...","¡Listo!"];
    body='<div class="ai-loader"><div class="ai-orb">🤖</div><div style="font-weight:700;font-size:15px">Claude AI generando tu tutorial</div><div style="width:100%;max-width:370px" id="ai-steps-list">'+aiSteps.map(function(st,i){return '<div class="ai-step" id="ai-step-'+i+'">⭕ '+st+'</div>';}).join("")+'</div><div style="width:75%;max-width:280px"><div class="prog-bar"><div class="prog-fill" id="ai-prog" style="width:0%"></div></div><div style="font-size:10px;color:var(--mut);text-align:center;margin-top:3px" id="ai-pct">0%</div></div></div>';
    foot="";
  }

  else if(s.step===4){
    var flagsHtml='<div style="display:flex;gap:5px;margin-bottom:13px;flex-wrap:wrap">'+(s.quizOn?'<span class="badge b-purple">🧠 Quiz activado</span>':"")+(s.certOn?'<span class="badge" style="background:rgba(6,182,212,.12);color:#06B6D4">🎓 Certificado activado</span>':"")+(s.assignTo.length>0?'<span class="badge b-blue">👥 Asignado a '+s.assignTo.length+' persona'+(s.assignTo.length>1?"s":"")+'</span>':"")+'</div>';
    body='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:13px;gap:8px;flex-wrap:wrap"><div style="display:flex;align-items:center;gap:7px;padding:8px 12px;background:rgba(16,185,129,.07);border-radius:8px;border:1px solid rgba(16,185,129,.15);flex:1"><span style="color:var(--grn)">✓</span> <span style="font-weight:600;color:var(--grn);font-size:12px">Generado en '+s.lang+' · '+s.out+'</span></div></div>'
      +flagsHtml
      +s.steps.map(function(st,i){return '<div class="step-box"><div class="step-num">Paso '+st.num+'</div><div style="font-weight:700;font-size:12.5px;margin-bottom:3px">'+st.title+'</div><div style="font-size:12px;color:var(--lt);line-height:1.7">'+st.body+'</div></div>';}).join("");
    foot='<button class="btn btn-s btn-sm" onclick="newTutState={};openNewTut()">Crear otro</button><button class="btn btn-p btn-sm" onclick="saveTut()">✓ Publicar Tutorial</button>';
  }

  openModal(titles[s.step],body,foot||null,true);
  if(s.step!==3) hide("modal-foot"); else hide("modal-foot");
  if(foot){ $("modal-foot").innerHTML=foot; show("modal-foot"); }
}

async function runAIGeneration() {
  newTutState.step=3;
  renderNewTutStep();
  var s=newTutState;
  var aiStepsData=["Analizando fuente...","Extrayendo contenido...","Estructurando pasos...","Traduciendo al "+s.lang+"...","Aplicando formato "+s.out+"...","Optimizando...","¡Listo!"];
  
  for(var i=0;i<aiStepsData.length-1;i++){
    await new Promise(function(r){setTimeout(r,480+Math.random()*300);});
    var el=document.getElementById("ai-step-"+i);
    if(el){el.className="ai-step done";el.textContent="✓ "+aiStepsData[i];}
    var next=document.getElementById("ai-step-"+(i+1));
    if(next){next.className="ai-step cur";}
    var prog=document.getElementById("ai-prog");
    var pct=document.getElementById("ai-pct");
    var p=Math.round(((i+1)/aiStepsData.length)*100);
    if(prog)prog.style.width=p+"%";
    if(pct)pct.textContent=p+"%";
  }

  var prompt='Crea un tutorial de capacitacion en '+s.lang+' sobre: '+(s.title||s.url||'el tema indicado')+'. Area: '+s.dept+'. Tipo: '+(s.out==='video'?'video':s.out==='voice'?'audio':'texto')+'. Formato: PASO 1: titulo, descripcion. PASO 2: titulo, descripcion. Hasta PASO 5. Luego TIEMPO: X minutos.';


  var r=await callAI(prompt);
  var raw=r||fallbackContent(s.title||s.url,s.dept);
  var steps=parseSteps(raw);
  newTutState.steps=steps.length?steps:[{num:"1",title:"Proceso completo",body:raw}];
  
  var last=document.getElementById("ai-step-"+(aiStepsData.length-1));
  if(last){last.className="ai-step done";last.textContent="✓ "+aiStepsData[aiStepsData.length-1];}
  var prog=document.getElementById("ai-prog");
  if(prog)prog.style.width="100%";
  
  newTutState.step=4;
  renderNewTutStep();
}

function parseSteps(txt) {
  var steps=[],rx=/PASO\s*(\d+)[:\-]\s*([^\n]+)\n([\s\S]*?)(?=PASO\s*\d|TIEMPO|$)/gi,m;


  while((m=rx.exec(txt||""))!==null) steps.push({num:m[1],title:m[2].trim(),body:m[3].replace(/\n+$/,"").trim()});

  return steps;
}

function fallbackContent(topic,dept) {
  return "PASO 1: Preparacion inicial\nVerifica tus credenciales y accede al sistema.\n\nPASO 2: Acceso al modulo\nAbre la seccion requerida desde el menu principal.\n\nPASO 3: Ingreso de datos\nCompleta todos los campos requeridos correctamente.\n\nPASO 4: Procesamiento\nEjecuta la accion principal sin saltear pasos.\n\nPASO 5: Verificacion y cierre\nConfirma el resultado y guarda segun el protocolo de "+dept+".\n\nTIEMPO: 8 minutos";















}

function saveTut() {
  var s=newTutState;
  var newT={id:++nextId,userId:currentUser.id,title:s.title||s.url||"Tutorial sin título",type:s.out,lang:s.lang,dept:s.dept,views:0,completions:0,status:"published",created:new Date().toISOString().slice(0,10),duration:"~8 min",quizOn:s.quizOn,certOn:s.certOn,assignedTo:s.assignTo,favorite:false,steps:s.steps};
  tuts.unshift(newT);
  closeModal();
  buildSidebar();
  goPage(currentPage);
  toast("¡Tutorial creado y publicado!");
}

